# Required for evaluation API + logging — BASE_URL host MUST match JWT "aud" or you get 401 invalid token
# Example if aud is http://20.244.56.144/evaluation-service use that line exactly (no trailing slash).
BASE_URL=http://20.207.122.201/evaluation-service
# One line, no quotes: ACCESS_TOKEN=eyJhbGciOi...
ACCESS_TOKEN=

# Optional: local notification HTTP API (Postman uses this Bearer, not ACCESS_TOKEN)
PORT=3000
API_STUDENT_BEARER=dev-token-change-me
STUDENT_ID=1

# Optional only if you do NOT use ACCESS_TOKEN — then /auth is called with:
# CLIENT_ID=
# CLIENT_SECRET=
# EMAIL=
# ROLL_NO=
# ACCESS_CODE=
